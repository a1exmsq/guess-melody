# =============================================================================
# Spotify API Credentials
# Create an app at https://developer.spotify.com/dashboard
# Add http://localhost:5173/callback to the allowed redirect URIs
# =============================================================================
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_PORT=8080

# =============================================================================
# Database Configuration (uncomment for PostgreSQL)
# Default: H2 in-memory database (see application.yml)
# =============================================================================
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/guessmelody
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=your_password
